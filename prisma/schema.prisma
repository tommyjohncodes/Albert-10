// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id  String @id @default(uuid())
  name  String
  userId String
  orgId String?
  sandboxId String? @unique
  sandboxUpdatedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages Message[]
  sandboxInstances SandboxInstance[]
  agentFailures AgentFailure[]
  context ProjectContext?
}

enum MessageRole {
  USER
  ASSISTANT
}

enum MessageType {
  RESULT
  ERROR
  PROGRESS
}

enum SandboxState {
  RUNNING
  TERMINATED
  FAILED
}

model Message {
  id  String @id @default(uuid())
  content String
  role MessageRole
  type MessageType
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projectId String
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  fragment Fragment?
}

model Fragment {
  id  String @id @default(uuid())
  messageId String @unique
  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  sandboxUrl String
  title String
  summary String?
  files Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SandboxInstance {
  id String @id @default(uuid())
  sandboxId String @unique
  sandboxUrl String?
  state SandboxState @default(RUNNING)
  userId String
  orgId String?
  projectId String
  lastActiveAt DateTime @default(now())
  terminatedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([userId, state, lastActiveAt])
  @@index([projectId, createdAt])
}

model AgentFailure {
  id String @id @default(uuid())
  projectId String
  sandboxId String?
  errorType String
  errorMessage String?
  finishReason String?
  lastAssistantMessage String?
  summaryFound Boolean @default(false)
  filesCount Int @default(0)
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
}

model ProjectContext {
  id String @id @default(uuid())
  projectId String @unique
  summary String
  results Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model Usage {
  key String  @id
  points Int
  expire DateTime?
}

model OrgLlmSettings {
  orgId String @id
  provider String @default("openrouter")
  model String
  titleModel String?
  responseModel String?
  openrouterApiKey String?
  openrouterKeyUpdatedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LlmUsage {
  id String @id @default(uuid())
  userId String?
  orgId String?
  provider String
  model String
  promptTokens Int @default(0)
  completionTokens Int @default(0)
  totalTokens Int @default(0)
  costUsd Float @default(0)
  createdAt DateTime @default(now())
}

model SandboxUsage {
  id String @id @default(uuid())
  projectId String
  userId String?
  orgId String?
  date DateTime
  seconds Int @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, date])
}

model PlatformSettings {
  id String @id
  vercelAccessToken String?
  vercelTokenUpdatedAt DateTime?
  updatedByUserId String?
  updatedAt DateTime @default(now()) @updatedAt
}
